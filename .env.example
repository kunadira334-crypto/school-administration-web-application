# Salin nilai berikut ke Vercel > Project > Settings > Environment Variables
GOOGLE_SPREADSHEET_ID=masukkan_id_spreadsheet
GOOGLE_SERVICE_ACCOUNT_EMAIL=nama-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMASUKKAN_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Opsional, diperlukan hanya untuk upload logo ke Google Drive.
# Buat folder Drive, bagikan sebagai Editor ke email service account, lalu isi ID folder.
GOOGLE_DRIVE_FOLDER_ID=masukkan_id_folder_drive
